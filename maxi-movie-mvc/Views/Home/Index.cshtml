@model List<Pelicula>
@{
    ViewData["Title"] = "Home Page";
}

<main class="flex-grow-1">
    <div class="container py-4">
        <div class="row g-3 mb-4 align-items-center">
        </div>

        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-4">
            @foreach (var pelicula in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="position-relative">
                            <img alt="@pelicula.Titulo" class="card-img-top" src="@pelicula.PosterUrlPortada">
                        </div>
                        <div class="card-body p-2">
                            <h5 class="card-title fs-6 fw-semibold mb-1">@pelicula.Titulo</h5>
                            <div class="d-flex align-items-center text-muted small">
                                    <span class="material-symbols-outlined text-warning me-1" style="font-size:1rem;"> star </span>
                                    <span>4.5</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</main>
